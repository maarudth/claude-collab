{
  "manifest_version": 3,
  "name": "Claude Collab",
  "version": "0.8.0",
  "description": "Connects Claude Code to your real browser — chat, point at elements, and build together inside the live page",
  "permissions": [
    "activeTab",
    "tabs",
    "scripting",
    "storage",
    "alarms",
    "debugger"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "service-worker.js"
  },
  "content_scripts": [{
    "matches": ["<all_urls>"],
    "js": ["content-script.js"],
    "run_at": "document_idle"
  }],
  "action": {
    "default_popup": "popup.html"
  }
}
